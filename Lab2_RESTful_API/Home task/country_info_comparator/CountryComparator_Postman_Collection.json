          ]
        },
        "url": "{{base_url}}/analyze"
      }
    },
    {
      "name": "POST /analyze validation error",
      "request": {
        "method": "POST",
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "country_a", "value": "P", "type": "text" },
            { "key": "country_b", "value": "Germany", "type": "text" },
            { "key": "from_year", "value": "2024", "type": "text" },
            { "key": "to_year", "value": "2010", "type": "text" }
          ]
        },
        "url": "{{base_url}}/analyze"
